// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "zed"
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "ssh_connections": [
    {
      "host": "github.com",
      "args": [],
      "projects": [],
    },
  ],
  "restore_on_startup": "launchpad",
  "terminal": {
    "font_family": "IosevkaTerm Nerd Font Propo",
  },
  "buffer_font_family": ".ZedMono",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "ui_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"],
    },
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.5",
      "enable_thinking": false
    },
    "sidebar_side": "right",
    "dock": "right",
    "commit_message_model": {
      "provider": "openai",
      "model": "gpt-5.4-nano",
    },
  },
}
